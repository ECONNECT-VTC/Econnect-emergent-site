# Serveur
PORT=8001

# MongoDB (Atlas recommandé)
MONGO_URL=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/DB_NAME?retryWrites=true&w=majority

# JWT
JWT_SECRET=change_me_long_random_string
JWT_ALGORITHM=HS256
JWT_EXPIRES_IN=7d

# Stripe
STRIPE_SECRET_KEY=sk_live_XXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXX

# URLs
FRONTEND_URL=https://econnect-vtc.com
BACKEND_URL=https://api.econnect-vtc.com

# CORS (si tu veux autoriser plusieurs origines)
CORS_ORIGINS=https://econnect-vtc.com,https://www.econnect-vtc.com

# Email (SendGrid)
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=no-reply@econnect-vtc.com

# (optionnel) pour les logs / environnement
ENV=production
